generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String                @id @default(cuid())
  clerkId               String                @unique
  name                  String?
  email                 String                @unique
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  profileViews          Int                   @default(0)
  monthlyProfileViews   Int                   @default(0)
  lastMonthProfileViews Int                   @default(0)
  accountSettings       AccountSettings?
  applications          Application[]
  autoApplySessions     AutoApplySession[]
  careerJourney         CareerJourney?
  chatSessions          ChatSession[]
  documents             Document[]
  interviewSessions     InterviewSession[]
  jobAlerts             JobAlert[]
  jobPreferences        JobPreferences?
  savedJobs             SavedJob[]
  skills                Skill[]
  assessments           SkillsAssessment[]
  subscriptions         Subscription[]
  profile               UserProfile?
  profileSnapshot       ProfileSnapshot?
  atsAnalysisHistory    AtsAnalysisHistory[]

  @@map("users")
}

model ProfileSnapshot {
  id        String   @id @default(cuid())
  userId    String   @unique
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profile_snapshots")
}

model AtsAnalysisHistory {
  id              String   @id @default(cuid())
  userId          String
  atsQualityScore Int
  jobMatchScore   Int?
  jobDescription  String?
  analysis        Json
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("ats_analysis_history")
}

model UserProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  firstName   String?
  lastName    String?
  phone       String?
  location    String?
  bio         String?
  avatar      String?
  linkedinUrl String?
  githubUrl   String?
  websiteUrl  String?
  title       String?
  company     String?
  experience  String?
  industry    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model AccountSettings {
  id                 String   @id @default(cuid())
  userId             String   @unique
  emailNotifications Boolean  @default(true)
  pushNotifications  Boolean  @default(true)
  jobAlerts          Boolean  @default(true)
  weeklyReports      Boolean  @default(true)
  marketingEmails    Boolean  @default(false)
  profileVisibility  String   @default("private")
  showEmail          Boolean  @default(false)
  showPhone          Boolean  @default(false)
  language           String   @default("en")
  timezone           String   @default("UTC")
  dateFormat         String   @default("MM/DD/YYYY")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account_settings")
}

model JobPreferences {
  id             String   @id @default(cuid())
  userId         String   @unique
  desiredRoles   Json     @default("[]")
  industries     Json     @default("[]")
  locations      Json     @default("[]")
  remoteWork     Boolean  @default(false)
  salaryMin      Int?
  salaryMax      Int?
  salaryCurrency String   @default("USD")
  careerLevel    String?
  jobType        Json     @default("[]")
  companySize    Json     @default("[]")
  skills         Json     @default("[]")
  keywords       Json     @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("job_preferences")
}

model Document {
  id          String   @id @default(cuid())
  userId      String
  name        String
  type        String
  fileName    String
  fileSize    Int
  mimeType    String
  fileUrl     String
  isPrimary   Boolean  @default(false)
  description String?
  tags        Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@map("documents")
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String
  planName             String
  planType             String
  status               String    @default("active")
  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  amount               Int
  currency             String    @default("usd")
  interval             String    @default("month")
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("subscriptions")
}

model Skill {
  id          String    @id @default(cuid())
  userId      String
  name        String
  category    String
  proficiency String
  level       Int       @default(1)
  verified    Boolean   @default(false)
  verifiedBy  String?
  verifiedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, category])
  @@map("skills")
}

model CareerJourney {
  id             String            @id @default(cuid())
  userId         String            @unique
  currentGoal    String?
  timeline       String?
  targetRole     String?
  targetIndustry String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  milestones     CareerMilestone[]

  @@map("career_journeys")
}

model CareerMilestone {
  id              String        @id @default(cuid())
  careerJourneyId String
  title           String
  description     String?
  type            String
  status          String        @default("planned")
  targetDate      DateTime?
  completedDate   DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  careerJourney   CareerJourney @relation(fields: [careerJourneyId], references: [id], onDelete: Cascade)

  @@index([careerJourneyId])
  @@map("career_milestones")
}

model SkillsAssessment {
  id          String    @id @default(cuid())
  userId      String
  title       String
  type        String
  score       Int?
  maxScore    Int?
  status      String    @default("in_progress")
  results     Json?
  feedback    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@map("skills_assessments")
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("tasks")
}

model Company {
  id          String   @id @default(cuid())
  name        String
  logo        String?
  website     String?
  description String?
  industry    String?
  size        String?
  location    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  jobs        Job[]

  @@map("companies")
}

model Job {
  id                 String               @id @default(cuid())
  title              String
  description        String
  companyId          String?
  location           String?
  type               String
  level              String?
  salary             String?
  requirements       String?
  benefits           String?
  postedAt           DateTime             @default(now())
  expiresAt          DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  applications       Application[]
  interviewSessions   InterviewSession[]
  company            Company?             @relation(fields: [companyId], references: [id])
  savedJobs          SavedJob[]

  @@index([companyId])
  @@map("jobs")
}

model Application {
  id            String    @id @default(cuid())
  userId        String
  jobId         String
  status        String    @default("APPLIED")
  coverLetter   String?
  resumeUrl     String?
  notes         String?
  interviewDate DateTime?
  interviewType String?
  appliedAt     DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  job           Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([userId])
  @@index([jobId])
  @@map("applications")
}

model SavedJob {
  id      String   @id @default(cuid())
  userId  String
  jobId   String
  savedAt DateTime @default(now())
  job     Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([userId])
  @@index([jobId])
  @@map("saved_jobs")
}

model JobAlert {
  id         String    @id @default(cuid())
  userId     String
  name       String
  keywords   String
  location   String    @default("Any location")
  frequency  String    @default("weekly")
  isActive   Boolean   @default(true)
  lastSent   DateTime?
  newMatches Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
  @@map("job_alerts")
}

model ChatSession {
  id            String        @id @default(cuid())
  userId        String
  title         String        @default("New Chat")
  type          String
  lastMessageAt DateTime      @default(now())
  messageCount  Int           @default(0)
  context       Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  messages      ChatMessage[]
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([userId, lastMessageAt])
  @@map("chat_sessions")
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  role      String
  content   String
  tokens    Int?
  model     String?
  createdAt DateTime    @default(now())
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("chat_messages")
}

model AutoApplyLog {
  id                String           @id @default(cuid())
  sessionId         String
  jobTitle          String
  company           String
  jobUrl            String
  matchScore        Int?
  status            String
  questionsFound    Int              @default(0)
  questionsAnswered Int              @default(0)
  aiResponses       Json?
  failureReason     String?
  skipReason        String?
  createdAt         DateTime         @default(now())
  session           AutoApplySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("auto_apply_logs")
}

model AutoApplySession {
  id              String        @id @default(cuid())
  userId          String
  searchQuery     String
  location        String        @default("South Africa")
  jobType         String?
  maxApplications Int           @default(10)
  indeedEmail     String?
  approvalMode    String        @default("auto")
  loginToken      String?       @unique
  loginExpiresAt  DateTime?
  loginVncPort    Int?
  loginSecretHash String?
  status          String        @default("pending")
  totalFound      Int           @default(0)
  appliedCount    Int           @default(0)
  skippedCount    Int           @default(0)
  failedCount     Int           @default(0)
  lastError       String?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  logs            AutoApplyLog[]
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("auto_apply_sessions")
}

model InterviewQuestion {
  id            String            @id @default(cuid())
  sessionId     String
  questionText  String
  category      String?
  order         Int               @default(0)
  timeLimitSecs Int               @default(120)
  createdAt     DateTime          @default(now())
  session       InterviewSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  response      InterviewResponse?

  @@index([sessionId])
  @@map("interview_questions")
}

model InterviewReport {
  id                   String           @id @default(cuid())
  sessionId            String           @unique
  finalScore           Int
  answerQualityScore   Int?
  communicationScore   Int?
  confidenceScore      Int?
  engagementScore      Int?
  relevanceScore       Int?
  strengths            Json             @default("[]")
  weaknesses           Json             @default("[]")
  recruiterSummary     String?
  hiringRecommendation String?
  aiGeneratedInsights  Json?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  session              InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("interview_reports")
}

model InterviewResponse {
  id                 String          @id @default(cuid())
  questionId         String          @unique
  videoUrl           String?
  audioUrl           String?
  durationSecs       Int?
  transcript         String?
  clarityScore       Int?
  confidenceScore    Int?
  relevanceScore     Int?
  communicationScore Int?
  emotionScore       Int?
  facialScore        Int?
  aiFeedback         String?
  keywordsMatched    Json?
  detailedAnalysis   Json?
  analysisStatus     String          @default("pending")
  analysisError      String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  question           InterviewQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("interview_responses")
}

model InterviewSession {
  id           String            @id @default(cuid())
  userId       String
  jobId        String?
  title        String            @default("Practice Interview")
  type         String            @default("behavioral")
  difficulty   String            @default("intermediate")
  status       String            @default("pending")
  overallScore Int?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  questions    InterviewQuestion[]
  report       InterviewReport?
  job          Job?              @relation(fields: [jobId], references: [id])
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("interview_sessions")
}
